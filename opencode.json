{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "directus-cms": {
      "type": "local",
      "command": ["npx", "-y", "@directus/content-mcp@latest"],
      "environment": {
        "DIRECTUS_URL": "YOUR_CMS_URL",
        "DIRECTUS_TOKEN": "YOUR_TOKEN"
      },
      "enabled": true
    }
  }
}